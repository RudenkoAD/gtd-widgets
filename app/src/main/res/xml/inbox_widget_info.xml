<?xml version="1.0" encoding="utf-8"?>
<!-- Провайдер виджета «Входящие». configure — активность выбора пространства
     (per-widget конфиг), запускается при добавлении виджета. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/inbox_widget_description"
    android:configure="com.gtdflow.widget.inbox.InboxConfigActivity"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/glance_default_loading_layout" />
