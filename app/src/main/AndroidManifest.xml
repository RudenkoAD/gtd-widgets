<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Напоминания по времени: уведомления (Android 13+), точный будильник, пересчёт после ребута -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Напоминания по месту (геофенсы, opt-in). Фоновая геолокация нужна, чтобы
         геофенс срабатывал, когда приложение не на переднем плане. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GtdFlow">

        <!-- Экран управления: статус vault, выбор папки, обновление, дамп для отладки -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Быстрый захват из виджета «Входящие» (нижний оверлей поверх домашнего экрана) -->
        <activity
            android:name=".ui.CaptureActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="adjustResize|stateVisible"
            android:theme="@style/Theme.GtdFlow.BottomSheet" />

        <!-- Приём шаринга (ACTION_SEND text/plain): открывает тот же оверлей захвата,
             préfill текстом/URL шаринга, запись в «Общее». Метка видна в share-меню. -->
        <activity
            android:name=".ui.ShareCaptureActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:label="@string/share_target_label"
            android:windowSoftInputMode="adjustResize|stateVisible"
            android:theme="@style/Theme.GtdFlow.BottomSheet">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Шторка деталей события/задачи (тап по элементу «Сегодня»/«Агенды») -->
        <activity
            android:name=".ui.EventSheetActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.GtdFlow.BottomSheet" />

        <!-- Малый оверлей правки задачи «Входящих» (тап по задаче) -->
        <activity
            android:name=".ui.InboxTaskSheetActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.GtdFlow.BottomSheet" />

        <!-- Конфигуратор виджета «Входящие»: выбор пространства -->
        <activity
            android:name=".inbox.InboxConfigActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.GtdFlow.Dialog">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Конфигуратор виджета «Агенда»: число дней -->
        <activity
            android:name=".agenda.AgendaConfigActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.GtdFlow.Dialog">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Виджет «Сегодня» -->
        <receiver
            android:name=".today.TodayWidgetReceiver"
            android:exported="true"
            android:label="@string/today_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_widget_info" />
        </receiver>

        <!-- Виджет «Входящие» -->
        <receiver
            android:name=".inbox.InboxWidgetReceiver"
            android:exported="true"
            android:label="@string/inbox_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/inbox_widget_info" />
        </receiver>

        <!-- Виджет «Агенда» -->
        <receiver
            android:name=".agenda.AgendaWidgetReceiver"
            android:exported="true"
            android:label="@string/agenda_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/agenda_widget_info" />
        </receiver>

        <!-- Напоминание по времени: срабатывание AlarmManager → показ уведомления -->
        <receiver
            android:name=".reminders.ReminderReceiver"
            android:exported="false" />

        <!-- Напоминание по месту: срабатывание геофенса (Play Services) → показ уведомления -->
        <receiver
            android:name=".reminders.GeofenceReceiver"
            android:exported="false" />

        <!-- Пересчёт и перепланирование напоминаний после перезагрузки телефона -->
        <receiver
            android:name=".reminders.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
